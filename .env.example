# LocusAI environment — copy to .env and fill in. NEVER commit the real .env.
# Only OPENAI_API_KEY + FLASK_SECRET_KEY are needed to boot locally; the rest
# unlock voice, SMS, billing, email, etc.

# ---- Core (required) ----
OPENAI_API_KEY=sk-...
FLASK_SECRET_KEY=            # generate: python -c "import secrets;print(secrets.token_hex(32))"
APP_ENV=development          # 'production' in prod
APP_BASE_URL=http://localhost:5050   # used for absolute URLs in emails + canonical/OG tags
# LOCUSAI_DB_PATH=/data/receptionist.db   # point at a persistent volume in prod

# ---- PII encryption (recommended) ----
ENCRYPTION_KEY=              # python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"

# ---- Voice (Retell + Telnyx) ----
RETELL_API_KEY=key_...
RETELL_DEFAULT_AGENT_ID=agent_7fe6433627a68c931f05b7ae84
RETELL_LLM_ID=llm_b41019c52636d5321f084e5bdbbb
RETELL_WEBHOOK_SECRET=       # verifies Retell webhooks — SET THIS IN PROD (voice mutation endpoints)
TELNYX_API_KEY=KEY...        # also covers SMS
# TELNYX_PHONE_NUMBER=+442046203253
# TELNYX_SIP_PASSWORD=       # outbound SIP credential password (rotate; keep out of git)

# ---- Stripe billing (optional until go-live — see BILLING_SETUP.md) ----
STRIPE_SECRET_KEY=sk_...
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BUSINESS=price_...

# ---- Google Calendar OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/integrations/google/callback

# ---- Email (SMTP) ----
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hello@locusai.co.uk

# ---- Web Push (PWA owner alerts, optional) ----
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@locusai.co.uk

# ---- Error monitoring (optional) ----
SENTRY_DSN=

# ---- Backups (optional off-box upload) ----
BACKUP_DIR=backups
BACKUP_KEEP=14
# BACKUP_S3_BUCKET=
# BACKUP_S3_PREFIX=locusai-db
# BACKUP_S3_ENDPOINT=
